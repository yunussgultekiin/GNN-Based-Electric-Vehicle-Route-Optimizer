# ==========================================
# GNN-Based EV Route Optimizer Environment
# Bu dosyayı kopyalayarak adını .env yapın
# ==========================================

# Docker ortamında çalışırken ML servisinin adresi (Container ismi)
ML_SERVICE_URL=http://energy-model:8001

# Eğer projeyi Docker OLMADAN, lokalde çalıştırıyorsanız yukarıdakini yorum satırı yapıp şunu kullanın:
# ML_SERVICE_URL=http://localhost:8001

# OSMnx Graf verilerinin indirileceği ve saklanacağı dizin
GRAPH_CACHE_DIR=data/graphs

# Sistemin açılışta kullanacağı varsayılan bölge
DEFAULT_REGION=Maltepe, Istanbul, Turkey